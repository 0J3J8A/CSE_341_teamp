{
  "swagger": "2.0",
  "info": {
    "title": "Vacation Planning API",
    "description": "Team 06 Project: Destinations, Reviews, Packages, and User Management.",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "General"
        ],
        "summary": "Welcome message",
        "description": "Endpoint to return a welcome message.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/packages/": {
      "get": {
        "tags": [
          "Packages"
        ],
        "summary": "Get all packages",
        "description": "Endpoint to retrieve all vacation packages.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Packages"
        ],
        "summary": "Create a new package",
        "description": "Endpoint to create a new vacation package.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Package data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "any"
                },
                "type": {
                  "type": "string",
                  "example": "any"
                },
                "destination": {
                  "type": "string",
                  "example": "any"
                }
              },
              "required": [
                "name",
                "type",
                "destination"
              ]
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/packages/findByType": {
      "get": {
        "tags": [
          "Packages"
        ],
        "summary": "Find packages by type",
        "description": "Endpoint to find vacation packages by their type. Use query parameter \"type\" to specify the package type (e.g., \"beach\", \"adventure\").",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Type of the package",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/packages/{id}": {
      "get": {
        "tags": [
          "Packages"
        ],
        "summary": "Get package by ID",
        "description": "Endpoint to retrieve a single vacation package by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Packages"
        ],
        "summary": "Update a package",
        "description": "Endpoint to update an existing vacation package by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Package data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "any"
                },
                "type": {
                  "type": "string",
                  "example": "any"
                },
                "destination": {
                  "type": "string",
                  "example": "any"
                }
              },
              "required": [
                "name",
                "type",
                "destination"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "delete": {
        "tags": [
          "Packages"
        ],
        "summary": "Delete a package",
        "description": "Endpoint to delete an existing vacation package by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/reviews/": {
      "get": {
        "tags": [
          "Reviews"
        ],
        "summary": "Get all reviews",
        "description": "Endpoint to retrieve all reviews.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Reviews"
        ],
        "summary": "Create a new review",
        "description": "Endpoint to create a new review.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Review data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "destination": {
                  "type": "string",
                  "example": "any"
                },
                "rating": {
                  "type": "number",
                  "example": 5
                },
                "comment": {
                  "type": "string",
                  "example": "This is a great destination!"
                }
              },
              "required": [
                "destination",
                "rating",
                "comment"
              ]
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/reviews/findByReview": {
      "get": {
        "tags": [
          "Reviews"
        ],
        "summary": "Search reviews by comment content",
        "description": "Endpoint to search for reviews based on comment content. Use query parameter \"q\" to specify the search term.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search term to match against review comments",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/reviews/{id}": {
      "get": {
        "tags": [
          "Reviews"
        ],
        "summary": "Get review by ID",
        "description": "Endpoint to retrieve a single review by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Reviews"
        ],
        "summary": "Update a review",
        "description": "Endpoint to update an existing review by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Review data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "destination": {
                  "type": "string",
                  "example": "any"
                },
                "rating": {
                  "type": "number",
                  "example": 5
                },
                "comment": {
                  "type": "string",
                  "example": "This is a great destination!"
                }
              },
              "required": [
                "destination",
                "rating",
                "comment"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": [
          "Reviews"
        ],
        "summary": "Delete a review",
        "description": "Endpoint to delete an existing review by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/users/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/destinations/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}