{
  "swagger": "2.0",
  "info": {
    "title": "Vacation Planning API",
    "description": "Team 06 Project: Destinations, Reviews, Packages, and User Management.",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": ["https"],

  "securityDefinitions": {
    "oauth2": {
      "type": "oauth2",
      "flow": "accessCode",
      "authorizationUrl": "https://accounts.google.com/o/oauth2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "scopes": {
        "openid": "OpenID Connect scope"
      }
    }
  },

  "paths": {
    "/": {
      "get": {
        "tags": ["General"],
        "summary": "Welcome message",
        "description": "Endpoint to return a welcome message.",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },

    "/packages/": {
      "get": {
        "tags": ["Packages"],
        "summary": "Get all packages",
        "description": "Retrieve all vacation packages.",
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Packages"],
        "summary": "Create a new package",
        "description": "Create a new vacation package.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "destination": { "type": "string" }
              },
              "required": ["name", "type", "destination"]
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" }
        },
        "security": [{ "oauth2": [] }]
      }
    },

    "/packages/findByType": {
      "get": {
        "tags": ["Packages"],
        "summary": "Find packages by type",
        "parameters": [
          { "name": "type", "in": "query", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" }
        }
      }
    },

    "/packages/{id}": {
      "get": {
        "tags": ["Packages"],
        "summary": "Get package by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not Found" }
        }
      },
      "put": {
        "tags": ["Packages"],
        "summary": "Update a package",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          { "name": "body", "in": "body", "required": true, "schema": { "type": "object" } }
        ],
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad Request" }
        },
        "security": [{ "oauth2": [] }]
      },
      "delete": {
        "tags": ["Packages"],
        "summary": "Delete a package",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not Found" }
        },
        "security": [{ "oauth2": [] }]
      }
    },

    "/reviews/": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Get all reviews",
        "responses": {
          "200": { "description": "OK" }
        }
      },
      "post": {
        "tags": ["Reviews"],
        "summary": "Create a new review",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "destination": { "type": "string" },
                "rating": { "type": "number" },
                "comment": { "type": "string" }
              },
              "required": ["destination", "rating", "comment"]
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" }
        }
      }
    },

