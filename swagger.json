
{
  "swagger": "2.0",
  "info": {
    "title": "Vacation Planning API",
    "description": "Team 06 Project: Destinations, Reviews, Packages, and User Management. Includes examples like Highlands Adventure, Boroko Market, and Ela Beach.",
    "version": "1.0.0"
  },
  "host": "cse-341-team-app.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {
    "/": {
      "get": {
        "tags": ["General"],
        "summary": "Welcome message",
        "description": "Endpoint to return a welcome message.",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/packages": {
      "get": {
        "tags": ["Packages"],
        "summary": "Get all packages",
        "description": "Endpoint to retrieve all vacation packages.",
        "responses": {
          "200": { "description": "List of packages" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Packages"],
        "summary": "Create a new vacation package",
        "description": "Endpoint to create a new vacation package.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Package data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "example": "Highlands Adventure" },
                "type": { "type": "string", "example": "Tour" },
                "price": { "type": "number", "example": 1200 },
                "duration": { "type": "string", "example": "7 days" },
                "description": { "type": "string", "example": "Explore the Highlands with guided hikes and cultural visits." },
                "availability": { "type": "boolean", "example": true }
              },
              "required": ["name", "type", "price", "duration", "description", "availability"]
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/packages/{id}": {
      "get": {
        "tags": ["Packages"],
        "summary": "Get package by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Package found" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Packages"],
        "summary": "Update a package",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "description": "Package data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "example": "Ela Beach Weekend" },
                "type": { "type": "string", "example": "Relaxation" },
                "price": { "type": "number", "example": 300 },
                "duration": { "type": "string", "example": "2 days" },
                "description": { "type": "string", "example": "Relax at Ela Beach with accommodation and meals included." },
                "availability": { "type": "boolean", "example": false }
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Updated successfully" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Packages"],
        "summary": "Delete a package",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Deleted successfully" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/packages/findByType": {
      "get": {
        "tags": ["Packages"],
        "summary": "Find packages by type",
        "parameters": [
          { "name": "type", "in": "query", "description": "Type of the package", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Matching packages" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Get all reviews",
        "description": "Endpoint to retrieve all reviews.",
        "responses": {
          "200": { "description": "List of reviews" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "tags": ["Reviews"],
        "summary": "Create a new review",
        "description": "Endpoint to create a new review.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Review data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "destination": { "type": "string", "example": "Boroko Market" },
                "rating": { "type": "number", "example": 5 },
                "comment": { "type": "string", "example": "Great experience, very lively place!" },
                "author": { "type": "string", "example": "Alison" }
              },
              "required": ["destination", "rating", "comment"]
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews/findByReview": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Search reviews by comment content",
        "description": "Use query parameter \"q\" to specify the search term.",
        "parameters": [
          { "name": "q", "in": "query", "description": "Search term", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Matching reviews" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews/{id}": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Get review by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Review found" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "tags": ["Reviews"],
        "summary": "Update a review",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "name": "body",
            "in": "body",
            "description": "Review data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "destination": { "type": "string", "example": "Ela Beach" },
                "rating": { "type": "number", "example": 4 },
                "comment": { "type": "string", "example": "Beautiful view, but crowded on weekends." },
                "author": { "type": "string", "example": "Visitor" }
              },
              "required": ["destination", "rating", "comment"]
            }
          }
        ],
        "responses": {
          "200": { "description": "Updated successfully" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "tags": ["Reviews"],
        "summary": "Delete a review",
              "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Deleted successfully" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    }
  }
}