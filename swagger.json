{
  "swagger": "2.0",
  "info": {
    "title": "Vacation APIs",
    "description": "APIs for managing vacation packages and reviews",
    "version": "1.0.0"
  },
  "host": "https://cse-341-team-app.onrender.com/",
  "basePath": "/",
  "schemes": ["https"],
  "paths": {
    "/": {
      "get": {
        "tags": ["General"],
        "summary": "Welcome message",
        "description": "Endpoint to return a welcome message.",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/packages/": {
      "get": {
        "summary": "Get all vacation packages",
        "responses": {
          "200": { "description": "List of packages" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "summary": "Create a new vacation package",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "price": { "type": "number" },
                "duration": { "type": "string" },
                "description": { "type": "string" },
                "availability": { "type": "boolean" }
              },
              "example": {
                "name": "Highlands Adventure",
                "type": "Tour",
                "price": 1200,
                "duration": "7 days",
                "description": "Explore the Highlands with guided hikes and cultural visits.",
                "availability": true
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/packages/{id}": {
      "get": {
        "summary": "Get a package by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Package found" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "summary": "Update a package by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "price": { "type": "number" },
                "duration": { "type": "string" },
                "description": { "type": "string" },
                "availability": { "type": "boolean" }
              },
              "example": {
                "name": "Ela Beach Weekend",
                "type": "Relaxation",
                "price": 300,
                "duration": "2 days",
                "description": "Relax at Ela Beach with accommodation and meals included.",
                "availability": false
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Updated successfully" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "summary": "Delete a package by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Deleted successfully" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/packages/findByType": {
      "get": {
        "summary": "Find packages by type",
        "parameters": [
          { "name": "type", "in": "query", "type": "string" }
        ],
        "responses": {
          "200": { "description": "Matching packages" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews/": {
      "get": {
        "summary": "Get all reviews",
        "responses": {
          "200": { "description": "List of reviews" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "summary": "Create a new review",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "destination": { "type": "string" },
                "rating": { "type": "integer" },
                "comment": { "type": "string" },
                "author": { "type": "string" }
              },
              "example": {
                "destination": "Boroko Market",
                "rating": 5,
                "comment": "Great experience, very lively place!",
                "author": "Alison"
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Created" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews/{id}": {
      "get": {
        "summary": "Get a review by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Review found" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "summary": "Update a review by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "destination": { "type": "string" },
                "rating": { "type": "integer" },
                "comment": { "type": "string" },
                "author": { "type": "string" }
              },
              "example": {
                "destination": "Ela Beach",
                "rating": 4,
                "comment": "Beautiful view, but crowded on weekends.",
                "author": "Visitor"
              }
            }
          }
        ],
        "responses": {
          "200": { "description": "Updated successfully" },
          "400": { "description": "Bad Request" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "summary": "Delete a review by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Deleted successfully" },
          "404": { "description": "Not Found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/reviews/findByReview": {
      "get": {
        "summary": "Find reviews by keyword",
        "parameters": [
          { "name": "q", "in": "query", "type": "string" }
        ],
        "responses": {
          "200": { "description": "Matching reviews" },
          "400": { "description": "Bad Request" },
          "500": { "description": "Internal Server Error" }
        }
      }
    }
  }
}
